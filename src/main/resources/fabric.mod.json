{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${version}",
	"name": "${mod_name}",
	"description": "Experimental Fabric-delivered backend project for bringing a native Metal renderer to Minecraft snapshots on macOS.",
	"authors": [
		"nkanf"
	],
	"contact": {},
	"license": "MIT",
	"icon": "assets/metalexp/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.nkanf.metalexp.MetalExpMod"
		],
		"client": [
			"dev.nkanf.metalexp.client.MetalExpClient"
		]
	},
	"mixins": [
		"metalexp.mixins.json",
		{
			"config": "metalexp.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "26.2-snapshot-1",
		"java": ">=25",
		"fabric-api": "*"
	}
}
